# Core
ECHOMIND_ENV=dev
ECHOMIND_LOG_LEVEL=INFO

# API
ECHOMIND_API_HOST=0.0.0.0
ECHOMIND_API_PORT=8000

# Dashboard
ECHOMIND_DASHBOARD_PORT=8501

# Data services
ECHOMIND_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/echomind
ECHOMIND_REDIS_URL=redis://redis:6379/0

# Worker
ECHOMIND_CELERY_BROKER_URL=redis://redis:6379/1
ECHOMIND_CELERY_RESULT_BACKEND=redis://redis:6379/2
