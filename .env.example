# Core
REMEMBRA_ENV=dev
REMEMBRA_LOG_LEVEL=INFO

# API
REMEMBRA_API_HOST=0.0.0.0
REMEMBRA_API_PORT=8000

# Dashboard
REMEMBRA_DASHBOARD_PORT=8501

# Data services
REMEMBRA_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/remembra
REMEMBRA_REDIS_URL=redis://redis:6379/0

# Worker
REMEMBRA_CELERY_BROKER_URL=redis://redis:6379/1
REMEMBRA_CELERY_RESULT_BACKEND=redis://redis:6379/2
